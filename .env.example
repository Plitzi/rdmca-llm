# ── RDMCA environment ─────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values you need:
#     cp .env.example .env
# `.env` is gitignored (never commit secrets); this template is tracked.
# Real shell environment variables always override values set here.

# HuggingFace token (optional) — raises download rate limits during data prep.
# Get a "Read" token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Compute backend override (optional): mlx | torch.
# Leave empty to auto-detect (MLX on Apple Silicon, else torch).
RDMCA_BACKEND=
