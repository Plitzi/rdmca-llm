# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Virtual environment ────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Generated artifacts (dist/) ───────────────────────────────────────────────
# Keep directory structure (.gitkeep), ignore the generated files
dist/checkpoints/**/*.npz
dist/checkpoints/**/*.opt
dist/checkpoints/**/*.json
dist/checkpoints/**/*.csv
dist/checkpoints/**/*.png
dist/benchmarks/*.json
dist/benchmarks/*.csv
dist/tokenizer/*.model
dist/tokenizer/*.vocab
dist/tokenizer/tokenizer_info.json
# image/audio VQ-VAE tokenizers
dist/tokenizer/*vqvae*
# per-run / backup tokenizers and any scratch backups
dist/tokenizer*.bak/
dist/tokenizer/*.json
*.bak
*.bak/

# ── Training data (large downloads) ───────────────────────────────────────────
# Each stage owns its generated corpus inside its plugin package; the legacy
# data/ layout is kept ignored too for older checkouts.
data/**/*.jsonl
data/**/*.meta.json
src/models/**/data/**/*.jsonl
src/models/**/data/**/*.meta.json
src/models/**/data/**/*.val.jsonl

# ── Runtime outputs ────────────────────────────────────────────────────────────
logs/*.log
logs/*.json
dist/snapshots/*.npz
dist/snapshots/*.json
# long-term semantic store (consolidation)
data/runtime/ltss.db
# experience queue (chat → daemon)
data/runtime/experiences.jsonl

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── Editor ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Test ───────────────────────────────────────────────────────────────────────
.pytest_cache/

# ── Secrets / local env ──────────────────────────────────────────────────────
# Local environment (secrets like HF_TOKEN). .env.example is the tracked template.
.env

# ── Misc ───────────────────────────────────────────────────────────────────────
*.log
nohup.out

# ── Claude ─────────────────────────────────────────────────────────────────────
.claude/
